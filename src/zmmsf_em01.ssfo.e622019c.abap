* NEW CODE
  SELECT BDTER BDMNG MEINS
  UP TO 1 ROWS  FROM RESB
    INTO (GV_HD_BDTER, GV_BDMNG, GV_MEINS)
      WHERE RSNUM = GS_MSEG-RSNUM
        AND RSPOS = GS_MSEG-RSPOS
        AND RSART = GS_MSEG-RSART ORDER BY PRIMARY KEY.

  ENDSELECT.
