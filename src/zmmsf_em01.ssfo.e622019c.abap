* OLD CODE
*SELECT SINGLE MAKTX FROM MAKT INTO GV_MAKTX
*  WHERE MATNR = GS_MSEG-MATNR
*    AND SPRAS = 'S'.
*
* NEW CODE
SELECT MAKTX
UP TO 1 ROWS  FROM MAKT INTO GV_MAKTX
  WHERE MATNR = GS_MSEG-MATNR
    AND SPRAS = 'S' ORDER BY PRIMARY KEY.

ENDSELECT.
* END. 08-07-2026 - ATC - ATC-01

